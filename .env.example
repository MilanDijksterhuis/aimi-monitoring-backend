PORT=3002

# Sleutel voor het VPS cron script dat metrics/logs POST
METRICS_API_KEY=vervang-met-random-secret

# Sleutel voor het dashboard om GET endpoints te bevragen
ADMIN_API_KEY=vervang-met-ander-random-secret

# Pad naar de SQLite database (wordt automatisch aangemaakt)
METRICS_DB_PATH=./data/metrics.db

# Toegestaan CORS-domein voor het dashboard
ALLOWED_ORIGIN=https://aimi-development.nl
